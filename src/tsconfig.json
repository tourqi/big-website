{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "@/lib/*": ["src/lib/*"]
    },

    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.js"]
}
